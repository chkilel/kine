{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "none",
  "semi": false,
  "singleQuote": true,
  "printWidth": 120,
  "arrowParens": "always",
  "bracketSpacing": true,
  "sortTailwindcss": true,
  "htmlWhitespaceSensitivity": "ignore",
  "vueIndentScriptAndStyle": true,
  "sortPackageJson": true,
  "ignorePatterns": [
    ".bmad-core",
    ".vscode",
    ".claude",
    ".opencode",
    ".trae",
    "_bmad",
    "openspec",
    "docs",
    "references",
    "server/database/migrations/",
    "AGENTS.md",
    "pnpm-lock.yaml",
    ".DS_Store",
    "wrangler.jsonc",
    ".oxlintrc.json",
    "env.d.ts",
    ".ignore",
    ".gitignore",
    "package.json",
    ".env",
    "tsconfig.json",
    ".env.example",
    "tui.json",
    ".oxfmtrc.json",
    "opencode.jsonc",
    "worker-configuration.d.ts"
  ]
}