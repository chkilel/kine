{
  "name": "kine-desk",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build ",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "postinstall": "nuxt prepare",
    "cf-typegen": "wrangler types",
    "deploy:stage": "pnpm run build && wrangler deploy",
    "deploy:prod": "pnpm run build && wrangler deploy --config wrangler.production.jsonc",
    "db:gen": "drizzle-kit generate && node scripts/flatten-migrations.js",
    "db:mig:local": "wrangler d1 migrations apply DB",
    "db:mig:stage": "wrangler d1 migrations apply DB --remote",
    "db:mig:prod": "wrangler d1 migrations apply DB --remote --config wrangler.production.jsonc",
    "db:seed": "curl -X POST http://localhost:3000/api/db/seed",
    "db:seed:stage": "curl -X POST https://kine-stage.chkilel.workers.dev/api/db/seed",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxi typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@internationalized/date": "^3.12.1",
    "@pinia/colada": "^0.21.7",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "0.11.3",
    "@unovis/ts": "^1.6.5",
    "@unovis/vue": "^1.6.5",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "better-auth": "^1.6.9",
    "date-fns": "^4.1.0",
    "drizzle-orm": "1.0.0-beta.22",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "uuid": "^13.0.1",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "^1.2.26",
    "@iconify-json/lucide": "^1.2.104",
    "@iconify-json/simple-icons": "^1.2.80",
    "@nuxt/ui": "^4.7.1",
    "@pinia/colada-devtools": "^0.4.5",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "1.0.0-beta.22",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "esbuild",
      "maplibre-gl",
      "prisma",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  }
}