{
  "name": "kine-desk",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build ",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev",
    "postinstall": "nuxt prepare",
    "cf-typegen": "wrangler types",
    "deploy:stage": "pnpm run build && wrangler deploy",
    "deploy:prod": "pnpm run build && wrangler deploy --config wrangler.production.jsonc",
    "db:gen": "drizzle-kit generate && node scripts/flatten-migrations.js",
    "db:mig": "wrangler d1 migrations apply DB",
    "db:mig:stage": "wrangler d1 migrations apply DB --remote",
    "db:mig:prod": "wrangler d1 migrations apply DB --remote --config wrangler.production.jsonc",
    "db:seed": "curl -X POST http://localhost:3000/api/db/seed",
    "db:seed:stage": "curl -X POST https://staging.kinedesk.com/api/db/seed -H \"CF-Access-Client-Id: $CF_ACCESS_CLIENT_ID\" -H \"CF-Access-Client-Secret: $CF_ACCESS_CLIENT_SECRET\"",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxi typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@internationalized/date": "^3.12.2",
    "@pinia/colada": "^1.3.1",
    "@pinia/colada-nuxt": "^1.0.1",
    "@pinia/nuxt": "^0.11.3",
    "@unovis/ts": "^1.6.5",
    "@unovis/vue": "^1.6.5",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "better-auth": "^1.6.17",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^1.0.0-rc.4",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "^1.2.29",
    "@iconify-json/lucide": "^1.2.111",
    "@iconify-json/simple-icons": "^1.2.86",
    "@nuxt/ui": "^4.8.2",
    "@opentelemetry/api": "^1.9.1",
    "@pinia/colada-devtools": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^1.0.0-rc.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "packageManager": "pnpm@11.5.3"
}